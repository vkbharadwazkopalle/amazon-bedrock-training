# AWS region where your Bedrock model is enabled.
AWS_REGION=us-east-1

# Bedrock inference-profile / model ID to use. This must be a model you have
# enabled in the AWS console (Bedrock > Model access). Examples:
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# For gpt-oss reasoning models only: how hard the model "thinks" before
# answering (low | medium | high). Lower leaves more of the token budget for
# the actual answer; ignored for non-gpt-oss models like Claude.
REASONING_EFFORT=low

# Credentials are picked up from your standard AWS config (env vars, ~/.aws,
# or an attached role) - no need to put keys here.
